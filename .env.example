# ── Azure AD ──────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Datenbank ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=choose-a-secure-password

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_MSAL_TENANT_ID=your-tenant-id
VITE_MSAL_CLIENT_ID=your-client-id
# Oeffentliche Basis-URL (fuer Links in Notifications/Mails)
DPW_PUBLIC_URL=https://dpw.example.org
# Optional fuer Vite-Dev-Proxy
VITE_BACKEND_URL=http://localhost:8080

# ── GitHub Issue Creation ────────────────────────────────────────────────────────
# Fine Grained Personal Access Token mit issue read/write Berechtigung für reicham2/DPW.
# Wird vom Backend verwendet um Bug-Reports als Issues zu erstellen.
GITHUB_TOKEN=github_pat_...
# GitHub-Repository im Format owner/repo (Standard: reicham2/DPW)
GITHUB_REPO=reicham2/DPW

# ── MiData API ───────────────────────────────────────────────────────────────
# API-Key für MiData Zugriff
MIDATA_API_KEY=your-midata-api-key
# URL-Template; {group_id} wird durch die hinterlegte Gruppen-ID ersetzt
MIDATA_API_URL_TEMPLATE=https://db.scout.ch/de/groups/{group_id}/people.json
# Request-Timeout in Millisekunden
MIDATA_API_TIMEOUT_MS=8000

# ── Web Push / PWA Benachrichtigungen ───────────────────────────────────────
# Mit `make generate-vapid-keys` erzeugen und in .env eintragen.
DPW_VAPID_PUBLIC_KEY=
DPW_VAPID_PRIVATE_KEY=
# Kontaktadresse fuer den Push-Absender (empfohlen: mailto:...)
DPW_VAPID_SUBJECT=mailto:admin@example.com

# ── Debug-Authentifizierung (compile-time, hart getrennt) ───────────────────
# Diese Flags steuern, ob Debug-Authentifizierung überhaupt mitgebaut wird.
# In Produktiv-Builds MUSS beides 0 sein.
# Das Makefile setzt diese automatisch auf 1 (alle Make-Targets = Debug).
ENABLE_DEBUG_AUTH=0
FRONTEND_ENABLE_DEBUG_AUTH=0

# E-Mail-Adresse, die beim Microsoft-Login als Admin erzwungen wird
# (nur wirksam in Debug-Auth-Builds).
DEBUG_ADMIN_EMAIL=user@example.com

# ── Auto-Save ─────────────────────────────────────────────────────────────────
# VITE_AUTOSAVE_INTERVAL – Wie oft (in ms) Änderungen gespeichert werden. Standard: 1500
# VITE_AUTOSAVE_DEBOUNCE – true: Speichert nach letzter Aktion (Debounce).
#                          false: Speichert in festen Intervallen unabhängig von Aktionen.
#                          Standard: true
VITE_AUTOSAVE_INTERVAL=1500
VITE_AUTOSAVE_DEBOUNCE=true

# VITE_MIDATA_WEATHER_REFRESH_INTERVAL – Refresh-Intervall fuer MiData-Kinder und Wetter in ms. Standard: 900000 (15 Min.)
VITE_MIDATA_WEATHER_REFRESH_INTERVAL=900000
