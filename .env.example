# ============================================================================
# PFLICHTWERTE (ausfüllen)
# Diese Werte müssen gesetzt sein.
# ============================================================================

# Verschlüsselung für sensible App-Settings in der DB
DPW_CONFIG_ENCRYPTION_KEY=choose-a-long-random-secret

# ============================================================================
# OPTIONALE ENVs (standardmäßig auskommentiert)
#
# WICHTIG:
# - Wenn eine dieser ENVs gesetzt ist, hat sie IMMER Priorität.
# - Solche Werte sind dann im UI nicht änderbar (gesperrt).
# - Wenn nicht gesetzt, kommt der Wert aus der DB/Standard und ist im UI pflegbar.
# ============================================================================

# Azure AD (optional; sonst Initial-Setup ohne Login möglich)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Web Push (optional; sonst automatisch verschlüsselt in DB erzeugt/verwaltet)
# DPW_VAPID_PUBLIC_KEY=
# DPW_VAPID_PRIVATE_KEY=
# DPW_VAPID_SUBJECT=mailto:admin@example.com

# Frontend Runtime
# DPW_PUBLIC_URL=https://dpw.example.org

# GitHub Issue Creation
# GITHUB_TOKEN=github_pat_...
# GITHUB_REPO=reicham2/DPW

# MiData API
# MIDATA_API_KEY=your-midata-api-key
# MIDATA_API_URL_TEMPLATE=https://db.scout.ch/de/groups/{group_id}/people.json
# MIDATA_API_TIMEOUT_MS=8000

# WordPress / EventON
# DPW_WP_URL=https://pfadihue.ch
# DPW_WP_USER=DPWeb
# DPW_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Auto-Save / Refresh Runtime
# AUTOSAVE_INTERVAL=1500
# AUTOSAVE_DEBOUNCE=true
# MIDATA_WEATHER_REFRESH_INTERVAL=900000

# ---------------------------------------------------------------------------
# Build-/Dev-only Werte (nicht als Runtime-Websetting verwaltet)
# ---------------------------------------------------------------------------
# VITE_BACKEND_URL=http://localhost:8080
# DEBUG_ADMIN_EMAIL=user@example.com

