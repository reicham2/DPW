# ── Azure AD ──────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_MSAL_TENANT_ID=your-tenant-id
VITE_MSAL_CLIENT_ID=your-client-id

# ── GitHub Issue Creation ────────────────────────────────────────────────────────
# Fine Grained Personal Access Token mit issue read/write Berechtigung für reicham2/DPW.
# Wird vom Backend verwendet um Bug-Reports als Issues zu erstellen.
GITHUB_TOKEN=github_pat_...

# ── Debug ─────────────────────────────────────────────────────────────────────
# Auf true setzen um den Debug-Modus zu aktivieren.
# Im Debug-Modus kann man sich ohne Microsoft-Konto als beliebiger Benutzer anmelden.
#
# DEBUG          – Aktiviert die Debug-Endpoints im Backend:
#                  POST /auth/debug-login (Login ohne Microsoft-Token)
#                  GET  /debug/users      (Benutzerliste ohne Auth)
#                  Zusätzlich wird der Benutzer mit DEBUG_ADMIN_EMAIL
#                  automatisch als Admin eingestuft.
#
# VITE_DEBUG     – Zeigt den Debug-Login-Button im Frontend an.
#                  Sollte immer gleich wie DEBUG gesetzt werden.
#
# DEBUG_ADMIN_EMAIL – E-Mail-Adresse, die beim normalen Microsoft-Login
#                     automatisch die Admin-Rolle erhält (nur wenn DEBUG=true).
DEBUG=false
VITE_DEBUG=false
DEBUG_ADMIN_EMAIL=user@example.com

# ── Auto-Save ─────────────────────────────────────────────────────────────────
# VITE_AUTOSAVE_INTERVAL – Wie oft (in ms) Änderungen gespeichert werden. Standard: 1500
# VITE_AUTOSAVE_DEBOUNCE – true: Speichert nach letzter Aktion (Debounce).
#                          false: Speichert in festen Intervallen unabhängig von Aktionen.
#                          Standard: true
VITE_AUTOSAVE_INTERVAL=1500
VITE_AUTOSAVE_DEBOUNCE=true
